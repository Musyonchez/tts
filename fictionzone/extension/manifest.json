{
  "manifest_version": 3,
  "name": "FictionZone Chapter Copier",
  "version": "1.0",
  "description": "Extracts chapter content from fictionzone.net and copies it to clipboard for TTS.",
  "permissions": ["downloads", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://fictionzone.net/novel/*/*",
        "https://fictionzone.net/omniportal/fq/*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {}
}
